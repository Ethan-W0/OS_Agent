<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <property name="LOG_PATH" value="logs"/>
  <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n"/>

  <!-- 控制台输出 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- Agent 日志文件（按天滚动，保留 30 天） -->
  <appender name="AGENT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/agent.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/agent.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- SSH 操作专项日志 -->
  <appender name="SSH_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/ssh.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/ssh.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- 交互结构化日志（纯内容，无时间戳前缀） -->
  <appender name="INTERACTION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/interaction.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/interaction.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>90</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <!-- 只输出消息本身，不加日志框架前缀，保留格式块的可读性 -->
      <pattern>%msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- INTERACTION_LOG → 仅写 interaction.log，不输出到控制台 -->
  <logger name="INTERACTION_LOG" level="INFO" additivity="false">
    <appender-ref ref="INTERACTION_FILE"/>
  </logger>

  <!-- Agent 核心包 → 控制台 + agent.log -->
  <logger name="com.ran.cjb_agent.service.agent" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="AGENT_FILE"/>
  </logger>

  <logger name="com.ran.cjb_agent.agent" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="AGENT_FILE"/>
  </logger>

  <logger name="com.ran.cjb_agent.websocket" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="AGENT_FILE"/>
  </logger>

  <!-- SSH 操作 → 控制台 + ssh.log -->
  <logger name="com.ran.cjb_agent.service.ssh" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="SSH_FILE"/>
  </logger>

  <!-- 其他业务包 → 控制台 + agent.log -->
  <logger name="com.ran.cjb_agent" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="AGENT_FILE"/>
  </logger>

  <!-- 第三方库 → 仅控制台，INFO 级 -->
  <logger name="dev.langchain4j" level="INFO" additivity="false">
    <appender-ref ref="CONSOLE"/>
  </logger>

  <logger name="org.hibernate" level="WARN" additivity="false">
    <appender-ref ref="CONSOLE"/>
  </logger>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
